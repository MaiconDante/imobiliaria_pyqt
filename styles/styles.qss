QWidget {
    font-family: Arial;
    font-size: 14px;
}

QLabel {
    font-weight: bold;
}

QLineEdit {
    padding: 6px;
    border: 1px solid #ccc;
    border-radius: 6px;
}

QPushButton {
    background-color: #2d89ef;
    color: white;
    padding: 8px;
    border-radius: 6px;
}

QPushButton:hover {
    background-color: #1b5fbf;
}

QTableWidget {
    border: 1px solid #ccc;
    gridline-color: #ddd;
}